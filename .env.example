# OrionBelt Semantic Layer MCP — environment configuration
# Copy to .env and adjust as needed.

# OrionBelt Semantic Layer REST API URL (required)
API_BASE_URL=https://orionbelt.ralforion.com

# API credential — only needed when the API runs with AUTH_MODE=api_key.
# Leave unset for unauthenticated deployments (AUTH_MODE=none).
# API_KEY=
# Header the credential is sent in; must match the API's API_KEY_HEADER.
# API_KEY_HEADER=X-API-Key

# MCP transport: stdio | http | sse
MCP_TRANSPORT=stdio

# Bind host/port for HTTP/SSE transport
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=9000

# Cloud Run injects PORT at runtime; takes precedence over MCP_SERVER_PORT
# when set. Leave unset for local dev.
# PORT=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: console (pretty), json (structured), cloudrun (JSON + GCP severity)
LOG_FORMAT=console

# HTTP timeout in seconds
API_TIMEOUT=30
